# Path to your Beancount main file (read for account/currency autocomplete + validation)
SPROUT_LEDGER_MAIN_FILE=/path/to/main.bean
# Root dir for writing (defaults to the main file's directory if blank)
SPROUT_LEDGER_ROOT=
# single_file | month_file
SPROUT_WRITE_MODE=single_file
SPROUT_SINGLE_FILE_NAME=sprout.bean
SPROUT_MONTH_FILE_TEMPLATE=transactions/{year}/{year}-{month:02d}.bean
SPROUT_DEFAULT_TAG=sprout
SPROUT_DEFAULT_CURRENCY=USD
SPROUT_LOOKAHEAD_DAYS=0
SPROUT_DB_PATH=sprout.db
# Directory of the built frontend (set automatically in the Docker image)
SPROUT_STATIC_DIR=
